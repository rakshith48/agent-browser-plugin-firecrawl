    "prepublishOnly": "node --test"
  },
  "keywords": [
    "agent-browser",
    "agent-browser-plugin",
    "firecrawl",
    "browser-automation",
    "browser-provider",
    "cdp",
    "scraping",
    "web-scraping"
  ],
