{
  "name": "agent-browser-plugin-firecrawl",
  "version": "0.1.0",
  "description": "Firecrawl plugin for agent-browser: cloud browser provider (CDP) plus scrape/search/crawl/map commands",
  "type": "commonjs",
  "bin": {
    "agent-browser-plugin-firecrawl": "bin/plugin.js"
  },
  "files": [
