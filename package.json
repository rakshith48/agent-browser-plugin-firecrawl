  "homepage": "https://github.com/firecrawl/agent-browser-plugin-firecrawl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firecrawl/agent-browser-plugin-firecrawl.git"
  },
  "bugs": {
